API_LLM_BASE_URL="https://api.openai.com/v1"
API_LLM_MODEL="gpt-4.1-mini"
API_KEY=""

EMBEDDING_MODEL="text-embedding-nomic-embed-text-v1.5"
VECTOR_DIM="768"
